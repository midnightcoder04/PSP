# Hosted Supabase project URL (https://<project-ref>.supabase.co)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Browser-safe Supabase API key — RLS-protected.
# Prefix: sb_publishable_…  (replaces the legacy "anon key").
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Server-only Supabase API key — bypasses RLS. Used by scripts/seed.ts.
# Prefix: sb_secret_…  (replaces the legacy "service_role key").
# IMPORTANT: NO `VITE_` prefix — that would inline the key into the browser bundle.
# Keep this var in .env.local (gitignored) and your deploy host's secret store.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: enable in-memory dev-auth bypass for offline UI work.
# VITE_DEV_BYPASS=true

# Password reused across all four __rpc_test_* users created by scripts/rpc.test.ts.
# Any value ≥ 12 chars works. Never touches production — only used in integration tests
# that self-clean via afterAll.
RPC_TEST_PASSWORD=change-me-before-running-rpc-tests
